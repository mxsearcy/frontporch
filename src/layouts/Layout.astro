---
export interface Props {
  title?: string;
  description?: string;
  section?: string;
}

const {
  title = 'Frontporch',
  description = 'Independent news, mutual aid, organizing resources, and practical skills.',
  section = '',
} = Astro.props;

const fullTitle = title === 'Frontporch' ? title : `${title} — Frontporch`;

const nav = [
  { href: '/news',       label: 'News',       key: 'news' },
  { href: '/resources',  label: 'Resources',  key: 'resources' },
  { href: '/mutual-aid', label: 'Mutual Aid', key: 'mutual-aid' },
  { href: '/diy',        label: 'DIY',        key: 'diy' },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'light' || (!saved && !prefersDark)) {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body style="background:var(--bg);min-height:100vh;display:flex;flex-direction:column;">

    <a href="#main-content" class="skip-link">Skip to content</a>

    {section ? (
      <header style="background:var(--nav-bg);border-bottom:2px solid var(--nav-border);position:sticky;top:0;z-index:50;">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
          <div class="flex items-center justify-between h-14">
            <a href="/" style="font-family:Georgia,serif;font-size:1.35rem;color:var(--text);text-decoration:none;font-weight:400;letter-spacing:-0.02em;">
              Frontporch
            </a>
            <div class="flex items-center">
              <nav aria-label="Main navigation" class="hidden sm:flex items-center">
                {nav.map(({ href, label, key }) => (
                  <a
                    href={href}
                    class:list={['nav-link', { active: section === key }]}
                    aria-current={section === key ? 'page' : undefined}
                  >
                    {label}
                  </a>
                ))}
              </nav>

              <details class="sm:hidden relative ml-3">
                <summary
                  aria-label="Open navigation menu"
                  style="list-style:none;cursor:pointer;color:var(--muted);padding:0.25rem;"
                >
                  <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                  </svg>
                </summary>
                <nav
                  aria-label="Mobile navigation"
                  style="position:absolute;right:0;margin-top:0.25rem;width:11rem;background:var(--surface);border:1px solid var(--border);padding:0.25rem 0;z-index:100;"
                >
                  {nav.map(({ href, label, key }) => (
                    <a
                      href={href}
                      aria-current={section === key ? 'page' : undefined}
                      style="display:block;padding:0.4rem 1rem;font-size:0.875rem;color:var(--muted);text-decoration:none;"
                    >
                      {label}
                    </a>
                  ))}
                </nav>
              </details>

              <button
                id="theme-toggle"
                aria-label="Toggle light/dark theme"
                style="margin-left:1rem;padding:0.3rem 0.4rem;color:var(--muted);background:none;border:1px solid var(--border);cursor:pointer;line-height:1;font-size:0.9rem;"
              >
                <span class="theme-icon-dark" aria-hidden="true">☀</span>
                <span class="theme-icon-light" aria-hidden="true" style="display:none;">☾</span>
              </button>
            </div>
          </div>
        </div>
      </header>
    ) : (
      <div style="position:fixed;top:1rem;right:1.25rem;z-index:50;">
        <button
          id="theme-toggle"
          aria-label="Toggle light/dark theme"
          style="padding:0.3rem 0.4rem;color:var(--muted);background:var(--bg);border:1px solid var(--border);cursor:pointer;line-height:1;font-size:0.9rem;opacity:0.7;"
        >
          <span class="theme-icon-dark" aria-hidden="true">☀</span>
          <span class="theme-icon-light" aria-hidden="true" style="display:none;">☾</span>
        </button>
      </div>
    )}

    <main id="main-content" class={`flex-1 w-full ${section ? 'max-w-6xl mx-auto px-4 sm:px-6 py-8' : ''}`}>
      <slot />
    </main>

    <footer style="border-top:1px solid var(--border);margin-top:4rem;padding:2rem 0;">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <nav aria-label="Footer navigation" class="flex flex-wrap gap-5" style="font-size:0.8rem;color:var(--muted);">
          <a href="/sources">Sources</a>
          <a href="/contribute">Contribute</a>
          <a href="/about">About</a>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://liberapay.com/frontporch/donate" target="_blank" rel="noopener noreferrer" style="color:var(--accent);">Donate</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      var btn = document.getElementById('theme-toggle');
      function updateIcons() {
        var dark = document.documentElement.classList.contains('dark');
        document.querySelector('.theme-icon-dark').style.display = dark ? '' : 'none';
        document.querySelector('.theme-icon-light').style.display = dark ? 'none' : '';
      }
      updateIcons();
      btn.addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateIcons();
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
