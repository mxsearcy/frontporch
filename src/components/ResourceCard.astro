---
export interface Props {
  title: string;
  url: string;
  description: string;
  category: string;
  tags?: string[];
  type?: 'article' | 'book' | 'guide' | 'tool' | 'video' | 'course' | 'archive';
}

const { title, url, description, tags = [], type = 'article' } = Astro.props;
---

<article class="card">
  <div style="display:flex;align-items:baseline;justify-content:space-between;gap:0.5rem;margin-bottom:0.5rem;">
    <span class="section-label">{type}</span>
  </div>
  <h3 class="font-serif" style="font-size:0.95rem;line-height:1.4;margin-bottom:0.4rem;">
    <a href={url} target="_blank" rel="noopener noreferrer" style="color:var(--text);text-decoration:none;" class="card-title-link">
      {title}
    </a>
  </h3>
  <p style="font-size:0.8rem;color:var(--muted);margin-bottom:0.6rem;">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>

<style>
  .card-title-link:hover { color: var(--accent); }
</style>
