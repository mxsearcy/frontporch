---
export interface Props {
  title: string;
  href?: string;
  linkLabel?: string;
}

const { title, href, linkLabel = 'See all' } = Astro.props;
---

<div style="margin-bottom:1.5rem;padding-bottom:0.75rem;border-bottom:2px solid var(--border);">
  <div class="flex items-baseline justify-between gap-4">
    <h1 class="font-serif" style="font-size:1.8rem;color:var(--text);">{title}</h1>
    {href && (
      <a href={href} style="font-size:0.8rem;color:var(--muted);text-decoration:none;white-space:nowrap;flex-shrink:0;" class="see-all-link">
        {linkLabel} →
      </a>
    )}
  </div>
</div>

<style>
  .see-all-link:hover { color: var(--accent); }
</style>
