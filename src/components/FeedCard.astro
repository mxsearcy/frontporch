---
export interface Props {
  title: string;
  url: string;
  source: string;
  sourceUrl?: string;
  date?: string;
  summary?: string;
  tags?: string[];
}

const { title, url, source, sourceUrl, date, summary, tags = [] } = Astro.props;

const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
  : null;
---

<article class="card group">
  <div class="flex items-start justify-between gap-2 mb-2">
    <span class="section-label">
      {sourceUrl
        ? <a href={sourceUrl} target="_blank" rel="noopener noreferrer" style="color:var(--label);text-decoration:none;">{source}</a>
        : source}
    </span>
    {formattedDate && <time style="font-size:0.7rem;color:var(--label);">{formattedDate}</time>}
  </div>
  <h3 class="font-serif" style="font-size:0.95rem;line-height:1.4;margin-bottom:0.5rem;">
    <a href={url} target="_blank" rel="noopener noreferrer" style="color:var(--text);text-decoration:none;" class="card-title-link">
      {title}
    </a>
  </h3>
  {summary && <p style="font-size:0.8rem;color:var(--muted);overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;margin-bottom:0.6rem;">{summary}</p>}
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>

<style>
  .card-title-link:hover { color: var(--accent); }
</style>
