---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
---

<Layout title="About" section="about">
  <SectionHeader title="About" />

  <div style="max-width:40rem;">

    <!-- Art placeholder -->
    <div style="margin-bottom:2rem;border:1px dashed var(--border);padding:3rem 2rem;text-align:center;">
      <p style="font-size:0.8rem;color:var(--label);">[ art goes here ]</p>
    </div>

    <!-- Text placeholder -->
    <div style="color:var(--muted);font-size:0.95rem;line-height:1.8;">
      <p style="color:var(--text);font-style:italic;">Text coming soon.</p>
    </div>

  </div>
</Layout>
